#!/bin/sh

fetch() {
	player=$(eval "playerctl -l | head -n 1" 2>&1)
	symbol="<span> ´Çü </span>"
	name=$(eval "playerctl metadata title" 2>&1)
	artist=$(eval "playerctl metadata artist" 2>&1)
	case "$player" in
		"chromium"* )
			symbol="<span> ´ë¿ </span>"
			if [ -z "$artist" ]; then
				artist="via Chromium"
			fi
			return;;
		"firefox"* )
			player=$(playerctl metadata | grep url)
			case "$player" in
				*"youtube"* )
					symbol="<span> ´à¬ </span>"
					return;;
				*"reddit"* )
					symbol="<span> ´èü </span>"
					artist="via Reddit"
					return;;
				* )
					symbol="<span> ¾░ê╣ </span>"
					if [ -z "$artist" ]; then
						artist="via Firefox"
					fi
					return;;
			esac;;
		"spotify" )
			symbol="<span> ´å╝ </span>"
			return;;
	esac
}
process() {
	if [ -z "$name" ]; then
		name="Unknown media"
	fi
	if [ -z "$artist" ]; then
		artist="Unknown artist"
	fi
	if [ "$player" = "No players found" ]; then
		name="No media playing"
		artist="No media playing"
	fi
	if [ "${#name}" -gt "28" ]; then
		name="$(echo "$name" | cut -c1-25)..."
	fi
	if [ "${#artist}" -gt "28" ]; then
		artist="$(echo "$artist" | cut -c1-25)..."
	fi
	artist="<span style=\"italic\" weight=\"light\"> $artist </span>"
}

fetch
process
case "$1" in
	"-s" )
		echo "$symbol";;
	"-n" )
		echo "$name";;
	"-a" )
		echo "$artist";;
esac
